rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Both addresses are admins. Used in many places below — kept as a small
    // helper-like list so adding/removing an admin is one edit.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'houseoftherisingarts@gmail.com' ||
        request.auth.token.email == 'alex@lesalondesinconnus.com'
      );
    }

    // Curated-artist check. The flag lives at /members/{uid}/admin/flags.isArtist
    // so the user can never grant it to themselves — the rule on that subdoc is
    // admin-only write. Use this to gate publish actions in the Creator Studio
    // (Reads articles, Hot Seat submissions, public profile, etc).
    function isCuratedArtist() {
      return request.auth != null
        && exists(/databases/$(database)/documents/members/$(request.auth.uid)/admin/flags)
        && get(/databases/$(database)/documents/members/$(request.auth.uid)/admin/flags).data.isArtist == true;
    }

    // ── Members ──────────────────────────────────────────────────────────────
    // Any authenticated user can read any member profile (for public profile pages).
    // Each user can only write their own profile.
    match /members/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Admin-controlled flags (isArtist, etc). Owner can read their own flags
      // (so the UI knows what to unlock); admins are the only writers.
      match /admin/{docId} {
        allow read:  if request.auth != null
                     && (request.auth.uid == userId || isAdmin());
        allow write: if isAdmin();
      }

      // Creator Studio artist profile — bio, gallery, skill tree, links, etc.
      // Owner is the only writer; any authenticated visitor can read for the
      // public artist page. Public reads (anonymous) are gated for now until
      // Phase 1 confirms the safe-fields shape.
      match /artistProfile/{docId} {
        allow read:  if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Super Profile (Maestro tier) — owner-editable config doc for the
      // /{username} fullscreen portfolio page. Public read so anonymous
      // visitors can load the page; writes only by owner, AND only when
      // the admin has flipped maestroEnabled on the user's flags doc.
      // Gating maestroEnabled at the rules layer (not just the UI) means a
      // user who knows the schema still can't enable a Super Profile they
      // haven't been granted.
      match /superProfile/{docId} {
        allow read: if true;
        allow write: if request.auth != null
                     && request.auth.uid == userId
                     && exists(/databases/$(database)/documents/members/$(userId)/admin/flags)
                     && get(/databases/$(database)/documents/members/$(userId)/admin/flags).data.maestroEnabled == true;
      }

      // Personal Kanban board — strictly private to the owner.
      match /kanban/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Inspirosphere user videos ─────────────────────────────────────
      // Every video the member uploads from their profile lives here.
      // Anyone (signed-in) can READ — videos are always visible on the
      // owner's public profile page. Only the owner can create / fully
      // update / delete their own videos. Other signed-in users may write
      // ONLY a single-key increment to the viewCount field (the "I just
      // watched it" ping driven by the orb player). The rules guard the
      // shape strictly:
      //   • the diff against the existing doc must affect viewCount only,
      //   • the new viewCount must be exactly the old + 1.
      // featureStatus transitions: the owner can set 'none' → 'pending';
      // anything past pending (featured / rejected) is admin-only.
      match /videos/{videoId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.ownerUid == userId
                      && request.resource.data.viewCount == 0
                      && (request.resource.data.featureStatus == 'none'
                          || request.resource.data.featureStatus == 'pending');
        // Owner full-update path — same shape constraints as create.
        allow update: if request.auth != null && (
          // (1) Owner edits their own video. They may flip featureStatus
          //     to 'pending' (request feature) or back to 'none' (rescind)
          //     but cannot self-approve.
          (request.auth.uid == userId
           && request.resource.data.ownerUid == userId
           && (request.resource.data.featureStatus == 'none'
               || request.resource.data.featureStatus == 'pending'
               || request.resource.data.featureStatus == resource.data.featureStatus))
          // (2) Public view-count ping — any signed-in user may increment
          //     by exactly 1 and touch nothing else.
          || (request.auth != null
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
              && request.resource.data.viewCount == resource.data.viewCount + 1)
          // (3) Admin moderation — featureStatus → featured/rejected, plus
          //     reviewer metadata. Admins also keep the right to fix any
          //     field if they need to.
          || isAdmin()
        );
        allow delete: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      }
    }

    // ── Feature Requests ─────────────────────────────────────────────────────
    // When an artist clicks "Ask to be featured" inside the Creator Studio, a
    // doc is created here with the user's uid as the doc id (idempotent — one
    // pending request per user). Admins triage these from the Artistic CRM
    // ("Demandes" tab). Approving sets the corresponding feature* flags on
    // members/{uid}/admin/flags.
    //
    // Doc shape:
    //   uid, displayName, email, photoURL, askedAt,
    //   status: 'pending'|'approved'|'declined',
    //   decidedAt?, decidedByEmail?,
    //   note?  (admin's optional note)
    match /featureRequests/{userId} {
      allow read:   if isAdmin() || (request.auth != null && request.auth.uid == userId);
      // Owner can create their own request and resubmit (overwrite). Status
      // resets to 'pending' on owner write — admins are the only ones who can
      // mark approved/declined.
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.status == 'pending';
      allow update: if isAdmin()
                    || (request.auth != null
                        && request.auth.uid == userId
                        && request.resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    // ── Friendships ──────────────────────────────────────────────────────────
    // Doc ID is sorted([uid_a, uid_b]).join('_')
    // Either party can read; either party can create/update; either can delete.
    match /friendships/{friendshipId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.uids;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.uids;
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.uids;
    }

    // ── Conversations ─────────────────────────────────────────────────────────
    // Members of the conversation can read and write.
    match /conversations/{convId} {
      allow read, update: if request.auth != null
                          && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.members;

      match /messages/{msgId} {
        allow read:   if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.members;
        allow create: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.members
                      && request.auth.uid == request.resource.data.uid;
      }
    }

    // ── Events ───────────────────────────────────────────────────────────────
    // Public read on the event document itself (name, dates, description).
    match /events/{eventId} {
      allow read: if true;

      // Registrations: public read (powers room-count feed + timeline for all visitors).
      // Each user may only write their own registration.
      match /registrations/{regId} {
        allow read:  if true;
        allow write: if request.auth != null
                     && (request.auth.uid == regId
                         || request.auth.token.email == 'houseoftherisingarts@gmail.com');
      }

      // Carpools: public read; any authenticated user can create or join.
      // Only the driver (or admin) can delete their own carpool.
      match /carpools/{carpoolId} {
        allow read:   if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null
                      && (resource.data.driverUid == request.auth.uid
                          || request.auth.token.email == 'houseoftherisingarts@gmail.com');
      }

      // Teams: public read (member counts, chef info).
      // Only the admin can mutate team documents.
      match /teams/{teamId} {
        allow read:  if true;
        allow write: if request.auth != null
                     && request.auth.token.email == 'houseoftherisingarts@gmail.com';

        // Kanban tasks: any authenticated member can read, create, and update.
        // Only the task creator or admin can delete.
        match /tasks/{taskId} {
          allow read:   if request.auth != null;
          allow create: if request.auth != null;
          allow update: if request.auth != null;
          allow delete: if request.auth != null
                        && (resource.data.createdBy == request.auth.uid
                            || request.auth.token.email == 'houseoftherisingarts@gmail.com');
        }
      }

      // Performances (Arts team show proposals): public read,
      // authenticated users can create their own, delete their own (or admin).
      match /performances/{perfId} {
        allow read:   if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null
                      && (resource.data.uid == request.auth.uid
                          || request.auth.token.email == 'houseoftherisingarts@gmail.com');
        allow update: if request.auth != null
                      && request.auth.token.email == 'houseoftherisingarts@gmail.com';
      }

      // Abundance offers (zone d'abondance): public read,
      // each user owns their own doc (keyed by uid).
      match /abundance/{userId} {
        allow read:   if true;
        allow write:  if request.auth != null && request.auth.uid == userId;
      }

      // Ceilidh needs: public read; ANY signed-in member can post a need (the
      // creator stamps their uid + email on the doc). Delete is restricted to
      // the original creator or admin. Updates allow editing your own doc OR
      // bumping just the `claims` field as anyone-can-claim.
      match /needs/{needId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null
                      && (resource.data.createdBy == request.auth.uid || isAdmin());
        allow update: if request.auth != null
                      && (resource.data.createdBy == request.auth.uid
                          || isAdmin()
                          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['claims']));
      }

      // ── Chats ──────────────────────────────────────────────────────────────
      // General Ceilidh chat — any signed-in member can post; everyone reads.
      // Admin can delete any message; anyone else only their own.
      match /chats/{room}/messages/{msgId} {
        allow read:   if true;
        allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.uid;
        allow delete: if request.auth != null
                      && (resource.data.uid == request.auth.uid || isAdmin());
        allow update: if isAdmin();
      }

      // Per-team chat — same shape as general. The team doc id is the segment.
      match /teamChats/{teamId}/messages/{msgId} {
        allow read:   if true;
        allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.uid;
        allow delete: if request.auth != null
                      && (resource.data.uid == request.auth.uid || isAdmin());
        allow update: if isAdmin();
      }

      // Show tickets: public read for spot counting; Cloud Function (admin SDK) writes.
      // Admin can delete. Users cannot write directly.
      match /showTickets/{ticketId} {
        allow read:   if true;
        allow delete: if request.auth != null
                      && request.auth.token.email == 'houseoftherisingarts@gmail.com';
        allow write:  if false;
      }
    }

    // ── Market: resources (material lend/borrow) ────────────────────────────
    // Members list cameras, lights, tools, etc. they can lend or trade. Owner
    // controls their own listing; everyone signed-in can browse.
    match /marketResources/{resourceId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerUid;
      allow update, delete: if request.auth != null
                    && (request.auth.uid == resource.data.ownerUid || isAdmin());
    }

    // ── Market: Foire (peer resale + bidding for puzzles & skins) ──────────
    // Sellers list a completed puzzle or owned skin; anyone signed-in can bid.
    // Bids must strictly raise `currentBid`; the seller can accept the top bid
    // (transitions status → sold) or cancel (status → cancelled). Item escrow
    // is enforced client-side: when a listing is created, the seller removes
    // the item from their displayCase / purchasedSkins; on sold, the buyer
    // adds it; on cancelled, the seller adds it back.
    match /marketListings/{listingId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.sellerUid
                    && request.resource.data.status == 'active'
                    && (request.resource.data.kind == 'puzzle'
                        || request.resource.data.kind == 'skin');
      // Update permitted in three shapes:
      //   1. A bid: anyone signed-in raises currentBid, sets currentBidderUid/Name + bidCount, status stays active
      //   2. Seller accepts: only the seller, status → 'sold'
      //   3. Seller cancels: only the seller, status → 'cancelled'
      // We also let any user write `previousBidderRefunded: true` after they
      // refund the previous bidder in their own profile doc (audit log only).
      allow update: if request.auth != null && (
        // (1) Bid raise — listing must be active + new bid strictly higher
        (resource.data.status == 'active'
         && request.resource.data.status == 'active'
         && request.resource.data.currentBid > resource.data.currentBid
         && request.resource.data.currentBidderUid == request.auth.uid)
        // (2) Seller accept
        || (request.auth.uid == resource.data.sellerUid
            && resource.data.status == 'active'
            && request.resource.data.status == 'sold')
        // (3) Seller cancel
        || (request.auth.uid == resource.data.sellerUid
            && resource.data.status == 'active'
            && request.resource.data.status == 'cancelled')
        // (4) Admin override
        || isAdmin()
      );
      allow delete: if request.auth != null
                    && (request.auth.uid == resource.data.sellerUid || isAdmin());
    }

    // ── Collab requests ──────────────────────────────────────────────────────
    // Submissions from the COLLABORATE tab (Residency / Event / Project).
    // The submitter is always the signed-in user (their uid is stamped on the
    // doc); admins triage from the CRM and write `adminResponse` + `status`.
    // The submitter sees their own requests + the admin reply on their profile.
    match /collabRequests/{requestId} {
      allow read:   if request.auth != null
                    && (request.auth.uid == resource.data.uid || isAdmin());
      allow list:   if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid
                    && request.resource.data.status == 'new'
                    && (request.resource.data.type == 'RESIDENCY'
                        || request.resource.data.type == 'EVENT'
                        || request.resource.data.type == 'PROJECT');
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Usernames (Super Profile slug claims) ────────────────────────────────
    // Doc id is the lowercase slug; body is { uid, slug, claimedAt }. Public
    // read so anonymous visitors can resolve /{username} → uid. Writes are
    // strictly the owner — they can claim a free slot or release their own.
    // Maestro gate enforced (claiming a slug also requires maestroEnabled),
    // so users without the flag can't squat usernames in advance.
    match /usernames/{slug} {
      allow read:   if true;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid
                    && exists(/databases/$(database)/documents/members/$(request.auth.uid)/admin/flags)
                    && get(/databases/$(database)/documents/members/$(request.auth.uid)/admin/flags).data.maestroEnabled == true;
      // Update only by owner, and they can't reassign the slug to another uid.
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      // Delete only by owner (slug release) or admin.
      allow delete: if request.auth != null
                    && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // ── Roster claims ────────────────────────────────────────────────────────
    // One doc per curated roster artist (id = stringified roster id). Created
    // when a member proves they ARE that artist (via the shared password held
    // by Alex). Once a claim exists, no other user can overwrite it — the rule
    // forbids both updates and same-id re-creates. Admins can clear a misclaim
    // via delete + re-create.
    match /rosterClaims/{rosterId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Puzzle gifts ─────────────────────────────────────────────────────────
    // A member can offer a completed puzzle from their display case to another
    // member. The recipient accepts (puzzle joins their case) or declines
    // (sender reclaims it). Either party can read; sender creates a 'pending'
    // gift; recipient transitions pending → accepted | declined; sender sets
    // reclaimed=true on a declined gift after re-adding the puzzle locally.
    match /puzzleGifts/{giftId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.fromUid
                      || request.auth.uid == resource.data.toUid);
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.fromUid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.fromUid != request.resource.data.toUid;
      allow update: if request.auth != null && (
        // Recipient accepts or declines a pending gift.
        (request.auth.uid == resource.data.toUid
         && resource.data.status == 'pending'
         && (request.resource.data.status == 'accepted' || request.resource.data.status == 'declined'))
        // Sender flags a declined gift as reclaimed after re-adding the puzzle.
        || (request.auth.uid == resource.data.fromUid
            && resource.data.status == 'declined'
            && request.resource.data.reclaimed == true)
      );
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.fromUid
                    && resource.data.status == 'pending';
    }

    // ── Studio chat rooms ────────────────────────────────────────────────────
    // Top-level themed chat rooms inside the Creator Studio. The room id is the
    // collection segment (e.g. "general", "studio", "misc"); message ids are
    // auto-generated. Anyone signed-in reads; signed-in members create with
    // their own uid stamped; the message owner (or admin) can delete.
    match /studioChats/{room}/messages/{msgId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid;
      allow delete: if request.auth != null
                    && (resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    // ── Show offers ──────────────────────────────────────────────────────────
    // Artists submit a performance offer (donation or paid). Anyone
    // authenticated may create one — the offer is non-destructive and
    // gates manual admin review. Reads + status changes are admin-only.
    match /events/{eventId}/showOffers/{offerId} {
      allow read:   if isAdmin();
      allow create: if request.auth != null
                    && request.resource.data.type in ['donation', 'paid']
                    && request.resource.data.status == 'new';
      allow update, delete: if isAdmin();
    }

    // ── Affiliate requests ───────────────────────────────────────────────────
    // Member asks to become an affiliate; admin approves with a personal code.
    // Doc keyed by uid. The user can read + create/update their own waiting
    // doc; admin reads all + writes status + code on approval/refusal.
    match /affiliateRequests/{userId} {
      allow read:   if request.auth != null
                    && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.status == 'waiting';
      allow update: if request.auth != null
                    && (
                      isAdmin()
                      || (request.auth.uid == userId
                          && request.resource.data.status == 'waiting')
                    );
      allow delete: if isAdmin();
    }

    // ── Weekly D20 rolls ─────────────────────────────────────────────────────
    // Each user has one doc at /d20Rolls/{uid} tracking their last roll, the
    // history (with any drawn rebate codes), and a pending surcharge total.
    // Anyone authenticated can read their own; admin reads any. Writes are
    // self-only and gated by the 7-day cooldown — rolls beyond that are
    // rejected at the rules layer (defence in depth on top of the client UI).
    match /d20Rolls/{userId} {
      allow read:  if request.auth != null
                   && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      // Self-write. The 7-day cooldown is enforced inside the dice
      // transaction (which reads lastRollAt before writing), and a manual
      // reset path ("meditate" passphrase) clears the field — both are
      // bounded one-write operations, so we don't gate the rule by time.
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // ── D20 rebate code pools ────────────────────────────────────────────────
    // Pre-loaded codes per tier (good=5%, great=10%, nat20=20%). Admin
    // populates these in advance from Hostaway. A successful roll claims
    // exactly one code by flipping `used` from false to true and stamping
    // usedBy/usedAt — all in a transaction. No-one can ever invent or reset
    // a code; only the owning admin can.
    match /d20Codes/{tier}/codes/{codeId} {
      // Authenticated users can list codes only via "where used == false";
      // we leave a permissive read but disclaim by treating values as opaque
      // until claimed. Admin reads everything for inventory views.
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      // A user may only "claim" a code: set used=true once, attach their uid.
      // They can never modify the code's value or unset used.
      allow update: if isAdmin()
                    || (request.auth != null
                        && resource.data.used == false
                        && request.resource.data.used == true
                        && request.resource.data.value == resource.data.value
                        && request.resource.data.usedBy == request.auth.uid);
    }
    // The tier doc itself (just a container) — read for collection traversal.
    match /d20Codes/{tier} {
      allow read:   if request.auth != null;
      allow write:  if isAdmin();
    }

    // ── Inspirosphere · admin-curated videos (Featured tab) ─────────────────
    // Alex uploads videos directly here for the "Featured" tab of the orb.
    // Public read (anyone signed-in can browse the orb); admin-only writes.
    match /inspirosphereCurated/{videoId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Inspirosphere · featured UGC (Voices tab) ───────────────────────────
    // Denormalized copy of approved user videos. Written by admin during
    // the "Approve" flow in AdminCRM (the source doc at
    // members/{ownerUid}/videos/{videoId} keeps `featureStatus: 'featured'`,
    // and we mirror its public fields here so the Voices tab is one read).
    // Public read, admin-only write.
    match /inspirosphereFeatured/{videoId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Wwoofers ─────────────────────────────────────────────────────────────
    // Wwoofer applications. Each wwoofer doc is keyed by uid.
    // The wwoofer can read/write their own profile; the admin can read/write any.
    match /wwoofers/{userId} {
      allow read:   if request.auth != null
                    && (request.auth.uid == userId
                        || request.auth.token.email == 'houseoftherisingarts@gmail.com');
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
                    && (request.auth.uid == userId
                        || request.auth.token.email == 'houseoftherisingarts@gmail.com');
      allow delete: if request.auth != null
                    && (request.auth.uid == userId
                        || request.auth.token.email == 'houseoftherisingarts@gmail.com');

      // Visit requests: the wwoofer creates them; admin can approve/decline; both read.
      match /visitRequests/{reqId} {
        allow read:   if request.auth != null
                      && (request.auth.uid == userId
                          || request.auth.token.email == 'houseoftherisingarts@gmail.com');
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if request.auth != null
                              && (request.auth.uid == userId
                                  || request.auth.token.email == 'houseoftherisingarts@gmail.com');
      }

      // Messages between wwoofer and admin. Either party can read.
      // Wwoofer creates with fromAdmin=false; admin creates with fromAdmin=true.
      match /messages/{msgId} {
        allow read: if request.auth != null
                    && (request.auth.uid == userId
                        || request.auth.token.email == 'houseoftherisingarts@gmail.com');
        allow create: if request.auth != null
                      && (
                        (request.auth.uid == userId && request.resource.data.fromAdmin == false)
                        || (request.auth.token.email == 'houseoftherisingarts@gmail.com' && request.resource.data.fromAdmin == true)
                      );
      }
    }

    // ── Production docs (Call sheets, shot lists, storyboards) ──────────────
    // Public read/write for collaborative production documents. Document IDs
    // are per-shoot (e.g. 'jour-1', 'jour-2'). The URL obscurity at
    // /callsheet is the only access control — acceptable for transient,
    // low-stakes production paperwork where the team needs zero-friction
    // editing. Revisit (passphrase, app check, admin-only) if the surface
    // widens or if vandalism becomes a real concern.
    match /production-docs/{docId} {
      allow read, write: if true;
    }
  }
}
