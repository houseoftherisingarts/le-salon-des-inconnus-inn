rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Members ──────────────────────────────────────────────────────────────
    // Each authenticated user can read and write their own profile.
    // The admin can read any profile (for future member management UI).
    match /members/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null
                  && request.auth.token.email == 'houseoftherisingarts@gmail.com';
    }

    // ── Events ───────────────────────────────────────────────────────────────
    // Public read on the event document itself (name, dates, description).
    match /events/{eventId} {
      allow read: if true;

      // Registrations: authenticated users can read all (for room-count feed),
      // but each user may only write their own registration.
      match /registrations/{regId} {
        allow read:  if request.auth != null;
        allow write: if request.auth != null
                     && (request.auth.uid == regId
                         || request.auth.token.email == 'houseoftherisingarts@gmail.com');
      }

      // Teams: public read (member counts, chef info).
      // Only the admin can mutate team documents.
      match /teams/{teamId} {
        allow read:  if true;
        allow write: if request.auth != null
                     && request.auth.token.email == 'houseoftherisingarts@gmail.com';

        // Kanban tasks: any authenticated member can read,
        // only the admin can create / update / delete.
        match /tasks/{taskId} {
          allow read:  if request.auth != null;
          allow write: if request.auth != null
                       && request.auth.token.email == 'houseoftherisingarts@gmail.com';
        }
      }
    }
  }
}
