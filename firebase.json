{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  },
  "hosting": [
    {
      "site": "inconnus-hub",
      "public": "apps/hub/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }],
      "headers": [
        { "source": "**/*.@(js|mjs|css)", "headers": [{ "key": "Cache-Control", "value": "max-age=31536000, immutable" }] },
        { "source": "**", "headers": [
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ] }
      ]
    },
    {
      "site": "inconnus-auberge",
      "public": "dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }],
      "headers": [
        { "source": "**/*.@(js|mjs|css)", "headers": [{ "key": "Cache-Control", "value": "max-age=31536000, immutable" }] },
        { "source": "**", "headers": [
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ] }
      ]
    },
    {
      "//": "Default project site — currently the one www.lesalondesinconnus.com resolves to. Mirrors inconnus-auberge until the custom domain is moved.",
      "site": "le-salon-des-inconnus",
      "public": "dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }],
      "headers": [
        { "source": "**/*.@(js|mjs|css)", "headers": [{ "key": "Cache-Control", "value": "max-age=31536000, immutable" }] },
        { "source": "**", "headers": [
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ] }
      ]
    },
    {
      "site": "inconnus-salon",
      "public": "apps/salon/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }],
      "headers": [
        { "source": "**/*.@(js|mjs|css)", "headers": [{ "key": "Cache-Control", "value": "max-age=31536000, immutable" }] },
        { "source": "**", "headers": [
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ] }
      ]
    },
    {
      "site": "inconnus-houseoftherisingarts",
      "public": "apps/houseoftherisingarts/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }],
      "headers": [
        { "source": "**/*.@(js|mjs|css)", "headers": [{ "key": "Cache-Control", "value": "max-age=31536000, immutable" }] },
        { "source": "**", "headers": [
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ] }
      ]
    },
    {
      "site": "inconnus-dome",
